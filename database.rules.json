{
  "rules": {
    "users": {
      ".read": "auth != null",
      ".indexOn": ["queryableName", "queryableEmail", "queryablePhone"],
      "$uid": {
        ".write": "$uid === auth.uid",
        "name": {
          ".validate": "newData.isString() && newData.val().length <= 100"
        },
        "queryableName": {
          ".validate": "newData.isString() && newData.val().length <= 100"
        },
        "email": {
          ".validate": "newData.isString() && newData.val().length <= 320"
        },
        "queryableEmail": {
          ".validate": "newData.isString() && newData.val().length <= 200"
        },
        "phoneNumber": {
          ".validate": "newData.isString() && newData.val().length <= 30"
        },
        "queryablePhone": {
          ".validate": "newData.isString() && newData.val().length <= 200"
        },
        "address": {
          ".validate": "newData.isString() && newData.val().length <= 500"
        },
        "maxPeople": {
          ".validate": "newData.isNumber() && newData.val() >= 0 && newData.val() <= 1000"
        },
        "emailVerified": {
          ".validate": "newData.isBoolean()"
        },
        "collection": {
          "$pushId": {
            "id": {
              ".validate": "newData.isString() && newData.val().length <= 20"
            },
            "name": {
              ".validate": "newData.isString() && newData.val().length <= 200"
            },
            "rating": {
              ".validate": "newData.isNumber() && newData.val() >= 0 && newData.val() <= 5"
            },
            "privateNote": {
              ".validate": "newData.isString() && newData.val().length <= 2000"
            },
            "publicNote": {
              ".validate": "newData.isString() && newData.val().length <= 2000"
            }
          }
        },
        "friends": {
          "$friendId": {
            ".write": "auth != null && $friendId === auth.uid && (newData.exists() ? root.child('users').child(auth.uid).child('friendRequests').child($uid).exists() : true)",
            ".validate": "newData.val() === true"
          }
        },
        "friendRequests": {
          "$fromUid": {
            ".write": "auth != null && $fromUid === auth.uid && !data.exists() && !root.child('users').child($uid).child('blocked').child(auth.uid).exists()",
            ".validate": "newData.val() === 'pending'"
          }
        },
        "blocked": {
          "$blockedUid": {
            ".validate": "newData.val() === true"
          }
        }
      }
    },
    "gatherings": {
      ".read": "auth != null",
      ".indexOn": ["host"],
      "$gatheringId": {
        ".write": "auth != null && (data.exists() ? data.child('host').val() === auth.uid : newData.child('host').val() === auth.uid)",
        "state": {
          ".validate": "newData.val() === 'pending' || newData.val() === 'confirmed' || newData.val() === 'canceled'"
        },
        "datetime": {
          ".validate": "newData.isString() && newData.val().length <= 40"
        },
        "host": {
          ".validate": "newData.isString() && newData.val().length <= 128"
        },
        "initiator": {
          ".validate": "newData.isString() && newData.val().length <= 128"
        },
        "maxGuests": {
          ".validate": "newData.isNumber() && newData.val() >= 0 && newData.val() <= 1000"
        },
        "guests": {
          "$guestUid": {
            ".write": "auth != null && $guestUid === auth.uid && data.exists()",
            ".validate": "newData.val() === 'invited' || newData.val() === 'accepted' || newData.val() === 'declined'"
          }
        },
        "games": {
          "$index": {
            "id": {
              ".validate": "newData.isString() && newData.val().length <= 20"
            },
            "name": {
              ".validate": "newData.isString() && newData.val().length <= 200"
            }
          }
        }
      }
    },
    ".read": false,
    ".write": false
  }
}
